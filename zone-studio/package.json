{
  "name": "sense360-zone-studio",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "Sense360 Zone Studio — radar/sensor zone configuration add-on",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"npm:dev:server\"",
    "dev:server": "ALLOW_ALL_ORIGINS=1 PROVIDER=mock tsx watch server/index.ts",
    "build": "npm run typecheck && npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "node esbuild.server.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "start": "node dist-server/index.cjs"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "@fastify/websocket": "^11.0.2",
    "fastify": "^5.2.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
